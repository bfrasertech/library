{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "library",
  "compatibility_date": "2026-04-04",
  "d1_databases": [
    {
      "binding": "library_lite",
      "database_name": "library-lite",
      "database_id": "535b63c1-673c-48bf-ba98-b82ba6484111",
      "migrations_dir": "d1/migrations",
    },
  ],
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "library-lite-vectors",
    },
  ],
}
